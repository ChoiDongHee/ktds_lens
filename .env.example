# 네이버 개발자센터(https://developers.naver.com/apps)에서 "검색" API를 활성화한 앱의
# Client ID/Secret을 콤마(,)로 구분해 배열처럼 나열하세요. 같은 순서(위치)의 ID/SECRET끼리
# 짝을 이룹니다. 앱(키)마다 별도의 1일 호출 한도가 있어서, 여러 개를 등록해두면 하나가
# 한도에 가까워졌을 때 자동으로 다음 키로 순환합니다. 하나만 쓴다면 각각 값 하나만 넣으면
# 됩니다. 개수 제한은 없습니다 (4개, 5개... 이어서 추가 가능).
#
# 예시(샘플, 실제 값 아님 - 아래 형식으로 채우면 됨):
# NAVER_CLIENT_IDS=abcd1234ef,ghij5678kl,mnop9012qr
# NAVER_CLIENT_SECRETS=ZyXwVu12,TsRqPo34,NmLkJi56
NAVER_CLIENT_IDS=
NAVER_CLIENT_SECRETS=

# 각 네이버 키의 1일 호출 한도 (기본값은 오픈API 기본 제공량인 25,000)
NAVER_DAILY_LIMIT=25000
# 한도 대비 이 비율(0.8 = 80%)에 도달하면 해당 키를 건너뛰고 다음 키로 순환, 등록된 키가
# 모두 이 비율에 도달하면 검색 결과가 없다는 안내로 처리됨
NAVER_LIMIT_THRESHOLD=0.8
# 네이버 오픈API 검색 종류: news(기본, 뉴스/시사성 질문에 적합, originallink 제공) 또는
# webkr/blog 등 다른 검색 종류로 변경 가능
NAVER_SEARCH_ENDPOINT=news
# 같은 네이버 키로 두 번째 검색 종류를 추가 등록 (엔진 이름: naver_web). 뉴스만으로는
# 놓치는 것(예: 실시간 주가 페이지 같은 일반 웹문서)을 보완. 비워두면 naver 하나만 사용.
NAVER_SEARCH_ENDPOINT_2=webkr
# 같은 네이버 키로 세 번째 검색 종류를 추가 등록 (엔진 이름: naver_encyc). 백과사전/용어
# 사전이라 "OO가 뭐야?" 같은 정의성 질문에 강함. 비워두면 등록 안 함.
NAVER_SEARCH_ENDPOINT_3=encyc

# 검색어 제목/스니펫에 아래 키워드가 있으면 결과에서 제외 (예: 반도체 주가 검색인데 스포츠
# 뉴스가 섞여 나오는 경우 방지). 10개 정도 넉넉히 가져온 뒤 걸러서 최종 개수만 반환하며,
# 원본 결과가 전부 걸러지면 "정책상 관련 키워드로 검색이 불가능합니다"로 응답하고 다른
# 엔진으로 자동 폴백함. 비워두면 필터링 없음.
EXCLUDE_KEYWORDS=야구,축구,농구,배구,골프,올림픽,월드컵,프로야구,K리그,e스포츠
EXCLUDE_OVERFETCH_COUNT=10

# 여러 엔진(특히 naver_encyc처럼 다른 성격의 검색 종류)의 결과를 합치면, 검색어와
# 우연히 한 단어만 겹칠 뿐 실제로는 무관한 결과가 섞일 수 있음(예: 주가 질문에 "영구 제모
# 효과" 사전 항목이 낀 사례). bm25_search 패키지와 동일한 BM25 모델로 각 결과의
# 제목+설명(description, 즉 엔진이 이미 돌려준 텍스트 -- 별도 요청 없음)을 검색어와 비교해,
# 이번 배치에서 가장 점수가 높은 결과 대비 RELEVANCE_MIN_SCORE_RATIO 미만인 것은 본문
# 보강(FETCH_CONTENT) 이전 단계에서 제외함 -- 관련 없는 링크에 본문 요청을 낭비하지 않기
# 위해서도 이 필터가 먼저 실행됨. false로 끄면 필터링 없이 각 엔진이 준 결과를 그대로 사용.
RELEVANCE_FILTER=true
# 0.15 = 최고점 대비 15% 미만인 결과 제외 (0에 가까울수록 관대함/1에 가까울수록 엄격함)
RELEVANCE_MIN_SCORE_RATIO=0.15

# web_search 자체가 상위 결과의 실제 페이지 본문을 가져와(trafilatura로 추출) 스니펫 대신
# 채워줌 (Tavily의 content 필드와 비슷한 형태). 전체 엔진 결과를 합쳐서 상위 N개까지만
# 시도하고, 내용이 부실(글자 수 미달, 보통 JS 렌더링 페이지)하면 건너뛰고 다음 후보로 넘어감.
# 실측: 네이버 3종 + 본문보강 ON 기준 평균 1.48초 (속도보다 답변 품질 우선 선택).
# 순수 속도만 원하면 false로 (네이버 뉴스 단일 엔진과 조합 시 평균 0.25초). README.md의
# "검색 속도 최적화" 섹션에 전체 비교표 있음.
FETCH_CONTENT=true
FETCH_CONTENT_TOP_N=3
FETCH_CONTENT_MAX_CHARS=3000
FETCH_CONTENT_MIN_USEFUL_CHARS=200
# 본문 가져오기 1건당 최대 대기 시간(초). trafilatura 자체 기본값(30초, 최대 20MB까지
# 허용)이 너무 관대해서, 후보 중 하나가 큰 PDF/바이너리면 그 한 건 때문에 전체 요청이
# 30초 넘게 걸릴 수 있음 (실측: OWASP 보안 가이드 PDF 하나로 37.9초 소요된 사례 발견).
FETCH_CONTENT_TIMEOUT_SECONDS=8

# 엔진 하나당 최대 대기 시간(초). 이 시간 안에 응답이 없으면 건너뛰고 로그에 남김(전체
# 요청이 느린 엔진 하나 때문에 무한정 늘어지는 것 방지). 요청된 엔진들은 전부 스레드풀로
# 동시에 실행되므로, 이 값은 "가장 느린 엔진 하나"의 최대 대기시간이지 합산 시간이 아님.
SEARCH_ENGINE_TIMEOUT_SECONDS=15

# 엔진 구성 프리셋: hybrid(duckduckgo+네이버 전부) / naver(네이버 계열만) / duckduckgo(덕덕고만).
# DEFAULT_ENGINES를 직접 지정하면 이 프리셋보다 우선함(아래 DEFAULT_ENGINES가 지정돼 있어
# 실제로는 이 프리셋이 적용되지 않지만, DEFAULT_ENGINES를 비우면 이 값이 쓰임).
SEARCH_ENGINE_MODE=naver

# web_search(engines="all") 호출 시 기본으로 사용할 엔진 목록 (콤마 구분) -- 지정하면
# SEARCH_ENGINE_MODE 프리셋 대신 이 목록을 그대로 사용. 실측 결과 DuckDuckGo(ddgs)는 내부적으로
# 여러 백엔드를 순회하는 방식이라 2~9초까지 걸리고 편차도 커서 기본에서 제외. 네이버 3종
# (뉴스+웹문서+백과사전, 본문보강 ON 기준 평균 1.48초)으로 속도보다 커버리지/답변 품질을
# 우선함 -- duckduckgo는 여전히 등록되어 있어 engines="duckduckgo"로 명시하면 그대로 쓸 수
# 있고, 순수 속도만 원하면 naver만 남기면 됨(평균 0.25초, FETCH_CONTENT=false와 조합 시).
DEFAULT_ENGINES=naver,naver_web,naver_encyc
# DEFAULT_ENGINES=naver
# DEFAULT_ENGINES=duckduckgo,naver,naver_web,naver_encyc

# 로그 설정 (기본: 프로젝트 폴더의 search.log, 콘솔(stderr)에도 함께 출력)
LOG_LEVEL=INFO
LOG_FILE=search.log

# 별도 호출 현황 로그: N초마다 엔진/네이버 키별 호출 수와 남은 한도를 hit_count.log에
# 기록 (search.log에도 동일 내용이 함께 남음). 자정이 지나면 이 주기 안에서 카운트가
# 자동으로 0으로 리셋됨(서버가 자정 넘겨 계속 떠있는 경우도 포함, 재시작 시에도 리셋됨).
HIT_COUNT_LOG_FILE=hit_count.log
HIT_COUNT_INTERVAL_SECONDS=60

# MCP 트랜스포트: "stdio"(기본, 클라이언트가 command+args로 직접 프로세스를 띄움, URL
# 없음) 또는 "sse"/"streamable-http"(네트워크 포트로 대기, URL로 등록 -- 여러 클라이언트가
# 공유 가능). sse/streamable-http일 때만 MCP_HOST/MCP_PORT가 적용됨.
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# test/webapp의 FastAPI 데모 챗봇이 사용하는 vLLM(Qwen) OpenAI 호환 엔드포인트
QWEN27B_VLLM_SERVER_URL=
QWEN27B_VLLM_MODEL_NAME=
QWEN27B_API_KEY=

# 검색 결과 개수 (엔진당). 본문 보강(FETCH_CONTENT 등)은 서버(server.py)가 처리하므로
# 여기서는 개수만 조절
WEBAPP_MAX_RESULTS=3
# test/webapp 전용 로그 파일 (상대경로면 test/webapp 폴더 기준으로 해석)
WEBAPP_LOG_FILE=webapp.log

# test/webapp에서 MCP web_search와 비교 테스트할 Tavily 검색 MCP 서버 키
# (https://tavily.com 에서 발급 -- LLM/RAG용으로 설계된 검색 API라 content 필드에
# 스니펫보다 긴 정제된 본문을 바로 제공함)
TAVILY_API_KEY=
